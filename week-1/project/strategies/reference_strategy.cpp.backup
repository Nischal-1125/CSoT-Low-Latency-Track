void ReferenceStrategy::on_fill(
    const Order& o,
    double fill_price,
    uint32_t fill_qty)
{
    (void)fill_price;

    size_t idx = get_symbol_index(o.symbol);

    if (o.side == Order::Side::BUY)
    {
        states_[idx].position += fill_qty;
    }
    else
    {
        states_[idx].position -= fill_qty;
    }
}

} // namespace csot

extern "C" csot::Strategy* create_strategy()
{
    return new csot::ReferenceStrategy();
}